{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/BackInStockDynamicButtonBorderStyles",
  "title": "BackInStockDynamicButtonBorderStyles",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": false
    },
    "color": {
      "type": "string",
      "example": "#000000",
      "default": "#000000"
    },
    "style": {
      "description": "Border pattern enumeration.",
      "type": "string",
      "example": "solid",
      "default": "solid",
      "enum": [
        "dashed",
        "dotted",
        "solid"
      ],
      "nullable": true
    },
    "width": {
      "type": "integer",
      "example": 1,
      "default": 1
    }
  }
}