{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SpinToWinProperties",
  "title": "SpinToWinProperties",
  "type": "object",
  "properties": {
    "display_device": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "both",
          "desktop",
          "mobile"
        ],
        "description": "Enumeration for mobile and desktop."
      }
    },
    "classname": {
      "type": "string",
      "nullable": true
    },
    "duplicate_slices": {
      "type": "boolean",
      "default": false
    },
    "slices": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/SpinToWinSliceConfig"
      }
    }
  },
  "required": [
    "slices"
  ]
}