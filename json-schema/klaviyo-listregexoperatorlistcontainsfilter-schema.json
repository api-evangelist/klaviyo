      "enum": [
        "contains-ends-with",
        "contains-starts-with",
        "not-contains-ends-with",
        "not-contains-starts-with"
      ]
    },
    "value": {
      "nullable": true,
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string"
        }
      ]
    }
  },
  "required": [
    "type",
    "operator",
    "value"
  ]
}