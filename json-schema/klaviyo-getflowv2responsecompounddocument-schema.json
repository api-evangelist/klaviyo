                }
              }
            }
          }
        },
        {
          "$ref": "#/components/schemas/FlowV2ResponseObjectResource"
        }
      ]
    },
    "included": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/FlowActionEncodedResponseObjectResource"
          },
          {
            "$ref": "#/components/schemas/TagResponseObjectResource"
          }
        ]
      }
    },
    "links": {
      "$ref": "#/components/schemas/ObjectLinks"
    }
  },
