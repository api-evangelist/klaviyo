{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/GreaterThanPositiveNumericFilter",
  "title": "GreaterThanPositiveNumericFilter",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "numeric"
      ]
    },
    "operator": {
      "type": "string",
      "enum": [
        "greater-than"
      ]
    },
    "value": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "number"
        }
      ]
    }
  },
  "required": [
    "type",
    "operator",
    "value"
  ]
}