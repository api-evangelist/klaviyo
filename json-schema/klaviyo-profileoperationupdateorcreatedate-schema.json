{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ProfileOperationUpdateOrCreateDate",
  "title": "ProfileOperationUpdateOrCreateDate",
  "type": "object",
  "properties": {
    "operator": {
      "description": "The type of operation to perform on a profile property.",
      "type": "string",
      "enum": [
        "create",
        "update"
      ]
    },
    "property_type": {
      "type": "string",
      "enum": [
        "date"
      ]
    },
    "property_key": {
      "type": "string"
    },
    "property_value": {
      "oneOf": [
        {
          "type": "string",
          "format": "date"
        },
        {
          "enum": [
            "today"
          ],
          "type": "string"
        }
      ]
    }
  },
  "required": [
    "operator",
    "property_type",
    "property_key",
    "property_value"
  ]
}