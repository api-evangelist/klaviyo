{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/RadioButtonsProperties",
  "title": "RadioButtonsProperties",
  "type": "object",
  "properties": {
    "display_device": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "both",
          "desktop",
          "mobile"
        ],
        "description": "Enumeration for mobile and desktop."
      }
    },
    "classname": {
      "type": "string",
      "nullable": true
    },
    "property_name": {
      "type": "string"
    },
    "label": {
      "type": "string",
      "nullable": true
    },
    "show_label": {
      "type": "boolean",
      "default": false
    },
    "required": {
      "type": "boolean",
      "default": false,
      "nullable": true
    },
    "error_messages": {
      "$ref": "#/components/schemas/ErrorMessages",
      "nullable": true
    },
    "options": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/PropertyOption"
      }
    },
    "placeholder": {
      "type": "string",
      "nullable": true
    }
  },
  "required": [
    "property_name",
    "options"
  ]
}