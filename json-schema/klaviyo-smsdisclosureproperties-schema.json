{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SMSDisclosureProperties",
  "title": "SMSDisclosureProperties",
  "type": "object",
  "properties": {
    "display_device": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "both",
          "desktop",
          "mobile"
        ],
        "description": "Enumeration for mobile and desktop."
      }
    },
    "classname": {
      "type": "string",
      "nullable": true
    },
    "content": {
      "oneOf": [
        {
          "$ref": "#/components/schemas/SMSDisclosureCustom"
        },
        {
          "$ref": "#/components/schemas/SMSDisclosureAccountDefault"
        }
      ]
    }
  }
}