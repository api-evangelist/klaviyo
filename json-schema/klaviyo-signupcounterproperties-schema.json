{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SignupCounterProperties",
  "title": "SignupCounterProperties",
  "type": "object",
  "properties": {
    "display_device": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "both",
          "desktop",
          "mobile"
        ],
        "description": "Enumeration for mobile and desktop."
      }
    },
    "classname": {
      "type": "string",
      "nullable": true
    },
    "timeframe": {
      "description": "Timeframes for the signup counter lookback.",
      "type": "string",
      "enum": [
        "1_hour",
        "24_hours",
        "30_days",
        "7_days"
      ]
    },
    "min_submits": {
      "type": "integer"
    },
    "content": {
      "type": "string"
    }
  },
  "required": [
    "timeframe",
    "min_submits",
    "content"
  ]
}